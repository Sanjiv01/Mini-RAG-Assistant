# --- LLM ---
# Default: 7B in 4-bit (fits 8GB VRAM). For CPU-only or if bitsandbytes
# misbehaves, set USE_4BIT=false and LLM_MODEL=Qwen/Qwen2.5-3B-Instruct.
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
USE_4BIT=true
LLM_DEVICE=auto            # auto | cuda | cpu
LLM_MAX_NEW_TOKENS=384

# --- Retrieval models (both small, run on CPU) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Pipeline knobs ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVE_K=20              # candidates fetched by hybrid search
FINAL_K=5                  # passed to LLM after rerank
CRAG_THRESHOLD=0.001       # min reranker probability to answer; raise (e.g. 0.05) for stricter refusal
CONTEXTUAL_RETRIEVAL=true  # prepend LLM-generated location preamble at ingestion

# --- Storage ---
CACHE_DIR=.cache
